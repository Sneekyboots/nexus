# SIX Oracle Service Configuration
# Copy this file to .env and fill in your actual values.

## SIX API Configuration
SIX_API_URL=https://api.six-group.com/web/v2
SIX_TEAM_ID=your_team_id_here
SIX_CERT_PATH=./certs/signed-certificate.pem
SIX_KEY_PATH=./certs/private-key.pem
# Only needed if private-key.pem is passphrase-protected
SIX_CERT_PASSWORD=

## SIX Rate Polling
SIX_POLL_INTERVAL_SECONDS=30

## Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

## NEXUS Program Configuration
FX_NETTING_PROGRAM_ID=2RfkQCsFUjtzX1PavSHF2ZgCQj9Ua1Q72pLAzd3KfnZ7
ORACLE_AUTHORITY_KEYPAIR=../../solana-keypairs/oracle-authority.json

## Logging
LOG_LEVEL=info

# FRONTEND (Vite)
# ============================================

# Solana RPC URL (public - devnet is free)
VITE_RPC_URL=https://api.devnet.solana.com

# FX Oracle URL (the Python sidecar service)
VITE_FX_ORACLE_URL=http://localhost:7070

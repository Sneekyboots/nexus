# Tenity API Configuration
TENITY_API_URL=https://api.tenity.com/v1
TENITY_API_KEY=your_api_key_here
TENITY_ACCOUNT_ID=your_account_id_here
TENITY_CERT_PATH=./tenity-cert.pem
TENITY_KEY_PATH=./tenity-key.pem

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Program IDs (will be populated after deployment)
ENTITY_REGISTRY_PROGRAM_ID=
POOLING_ENGINE_PROGRAM_ID=
COMPLIANCE_HOOK_PROGRAM_ID=
FX_NETTING_PROGRAM_ID=
SWEEP_TRIGGER_PROGRAM_ID=

# Keypair Paths
DEPLOYER_KEYPAIR=./solana-keypairs/deployer.json
ORACLE_AUTHORITY_KEYPAIR=./solana-keypairs/oracle-authority.json
